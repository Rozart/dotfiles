#alias mv='mv -v'
#alias cp='cp -v'
#alias rm='rm -v'

alias cat='bat'
alias grep='rg'
# --icons=always, not bare --icons: since eza 0.18 the flag takes an optional
# value, so `eza --icons ~/Downloads` swallows the path as the flag's argument.
alias ls='eza --group-directories-first --icons=always'
alias vim='nvim'
alias vi='nvim'
alias v='nvim'
alias sudovim='sudo -E nvim'
alias man='tldr --theme=base16'
alias brewup='brew update; brew upgrade; brew prune; brew cleanup; brew doctor'
alias docker-compose='docker compose'

# tmux aliases
alias t='tmux'
alias ta='t a -t'
alias tls='t ls'
alias tn='t new -t'

alias dev='cd ~/Dev '
alias envconf='cd ~/.config/'
alias wiki='cd {{ .obsidian_base }} && nvim .'

alias pl="export LANG=pl_PL.UTF-8 && export LC_ALL=pl_PL.UTF-8"
alias en="export LANG=en_US.UTF-8 && export LC_ALL=en_US.UTF-8"

alias gitwork="git config --local include.path $GITCONFIG_WORK"
alias gitprivate="git config --local include.path $GITCONFIG_PRIVATE"
alias gitpriv="gitprivate"
