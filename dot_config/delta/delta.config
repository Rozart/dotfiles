# Theme definitions. Each file defines one [delta "<slug>"] feature; including
# them all is cheap since only the one named by delta.features gets applied.
[include]
  path = ~/.config/delta/themes/sonokai-shusia.gitconfig
  path = ~/.config/delta/themes/rose-pine-dawn.gitconfig
  path = ~/.config/delta/themes/catppuccin-latte.gitconfig
  path = ~/.config/delta/themes/everforest-light.gitconfig
  path = ~/.config/delta/themes/tokyonight-day.gitconfig

# Fallback for a machine that has never run `theme`.
[delta]
  features = sonokai-shusia
  syntax-theme = sonokai-shusia

# Active theme, written by the `theme` fish function. Git silently ignores a
# missing include, and being last means it overrides the fallback above.
[include]
  path = ~/.config/delta/active.gitconfig
