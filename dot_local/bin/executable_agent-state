#!/usr/bin/env bash
# agent-state — surface an AI coding agent's state on its tmux window.
#
# Deliberately tool-agnostic: any client (Claude Code, Codex, aider, a Gemini
# CLI, ...) wires its own lifecycle hooks to this one command. Adding a tool
# means passing a different <tool> label — nothing here changes.
#
#   agent-state busy  claude    # working
#   agent-state wait  claude    # needs the human (genuine permission prompt)
#   agent-state idle  claude    # idle after done (~60s with no new prompt)
#   agent-state resume claude   # a tool ran — heal wait back to busy mid-turn
#   agent-state done  claude    # finished; badge persists until the window is viewed
#   agent-state sub+  claude    # a subagent started
#   agent-state sub-  claude    # a subagent finished
#   agent-state clear           # this pane's agent is gone
#   agent-state viewed <win>    # window was looked at; forget its finished agents
#
# State is owned per PANE, because a window routinely holds more than one agent
# session and they must not clobber each other:
#   @agent_pane_state    busy|wait|idle|done for this pane's agent
#   @agent_pane_subs     in-flight subagents spawned by this pane
#   @agent_pane_pending  this pane's loop stopped while subagents were still out
#   @agent_pane_seen     @agent_pane_subs as of this pane's last stop (staleness check)
#   @agent_pane_tool     label to render
#
# The window options the status bar actually reads are DERIVED from the panes on
# every change, never accumulated:
#   @agent_state  raw state, for tmux hooks to key off (see tmux.conf)
#   @agent_badge  pre-rendered status fragment, so window-status-format stays
#                 a single conditional instead of nested per-state ones
# Deriving is what makes this self-healing: a miscounted pane can make one badge
# wrong, but it can never wedge the window into a state it cannot leave.
#
# Colours are tmux palette names, not hex, so the badge follows whichever
# terminal theme is active without needing a per-theme entry.

set -euo pipefail

# Outside tmux there is nothing to decorate.
[ -n "${TMUX:-}" ] || [ "${1:-}" = viewed ] || exit 0

action=${1:-clear}
tool=${2:-agent}

pane_get() { tmux show-option -qvp -t "$1" "$2" 2>/dev/null || true; }
pane_set() { tmux set-option -p -t "$1" "$2" "$3" 2>/dev/null || true; }
pane_del() { tmux set-option -p -t "$1" -u "$2" 2>/dev/null || true; }

subs_of() {
	local n
	n=$(pane_get "$1" @agent_pane_subs)
	echo "${n:-0}"
}

# Recompute the window badge from whatever its panes currently claim. Priority is
# wait > busy > done: a pane blocked on the human outranks one that is merely
# working, which outranks one that has finished.
refresh_window() {
	local win=$1 p s rank best=0 state='' tool_label=agent total=0 n icon colour suffix=''

	while read -r p; do
		[ -n "$p" ] || continue
		s=$(pane_get "$p" @agent_pane_state)
		[ -n "$s" ] || continue
		n=$(subs_of "$p")
		total=$((total + n))
		case $s in
		wait) rank=4 ;;
		busy) rank=3 ;;
		idle) rank=2 ;;
		done) rank=1 ;;
		*) rank=0 ;;
		esac
		if [ "$rank" -gt "$best" ]; then
			best=$rank
			state=$s
			tool_label=$(pane_get "$p" @agent_pane_tool)
			tool_label=${tool_label:-agent}
		fi
	done < <(tmux list-panes -t "$win" -F '#{pane_id}' 2>/dev/null || true)

	if [ -z "$state" ]; then
		tmux set-option -w -t "$win" -u @agent_state 2>/dev/null || true
		tmux set-option -w -t "$win" -u @agent_badge 2>/dev/null || true
	else
		case $state in
		busy)
			icon='󰔟'
			colour=yellow
			;;
		wait)
			icon='󰀦'
			colour=red
			;;
		idle)
			icon='󰂚'
			colour=blue
			;;
		done)
			icon='󰄬'
			colour=green
			;;
		esac
		[ "$total" -gt 0 ] && suffix=" ×$total"
		tmux set-option -w -t "$win" @agent_state "$state" 2>/dev/null || true
		# Only fg is set: bg carries over from the surrounding window-status segment, and
		# the template re-asserts the full style afterwards. Emitting #[default] here would
		# reset bg to window-status-style and break the *current* window's highlight.
		tmux set-option -w -t "$win" @agent_badge "#[fg=$colour]$icon $tool_label$suffix" 2>/dev/null || true
	fi
	# Options alone don't always trigger a repaint; force one so the badge is immediate.
	tmux refresh-client -S 2>/dev/null || true
}

# A window was selected: forget the panes that had already finished, so "done"
# keeps meaning "done and you haven't looked". Panes still busy or waiting are
# describing the present and are left alone.
if [ "$action" = viewed ]; then
	win=${2:-}
	[ -n "$win" ] || exit 0
	while read -r p; do
		[ -n "$p" ] || continue
		if [[ "$(pane_get "$p" @agent_pane_state)" =~ ^(done|idle)$ ]]; then
			for o in @agent_pane_state @agent_pane_subs @agent_pane_pending @agent_pane_seen @agent_pane_tool; do
				pane_del "$p" "$o"
			done
		fi
	done < <(tmux list-panes -t "$win" -F '#{pane_id}' 2>/dev/null || true)
	refresh_window "$win"
	exit 0
fi

# Everything below mutates the calling pane's own state.
[ -n "${TMUX_PANE:-}" ] || exit 0
self=$TMUX_PANE

# Parallel subagent spawns fire their hooks near-simultaneously, so the counter's
# read-modify-write genuinely races.
# ponytail: no flock (macOS, minimal containers) degrades to the racy path rather
# than failing — a miscounted badge beats a hook that errors out.
lockfile="${TMPDIR:-/tmp}/agent-state.$(id -u).${self//[^a-zA-Z0-9]/_}.lock"
if command -v flock >/dev/null 2>&1; then
	exec 9>"$lockfile"
	flock 9
fi

case $action in
busy)
	# A fresh turn is the self-heal: whatever the counter drifted to last turn, it
	# starts from zero here.
	pane_set "$self" @agent_pane_state busy
	pane_set "$self" @agent_pane_tool "$tool"
	pane_set "$self" @agent_pane_subs 0
	pane_del "$self" @agent_pane_pending
	pane_del "$self" @agent_pane_seen
	;;
resume)
	# A tool just executed, which proves the loop is running again — the only signal
	# that exists for "the human answered the permission prompt". Unlike `busy` it
	# fires mid-turn, so it must not reset the subagent counter.
	pane_set "$self" @agent_pane_state busy
	pane_set "$self" @agent_pane_tool "$tool"
	;;
wait)
	# Blocked on the human means the loop is interactive again, so any subagents it
	# was tracking are no longer what this pane is waiting on.
	pane_set "$self" @agent_pane_state wait
	pane_set "$self" @agent_pane_tool "$tool"
	pane_set "$self" @agent_pane_subs 0
	pane_del "$self" @agent_pane_pending
	;;
idle)
	# idle_prompt fires ~60s after a turn ends. Only promote a finished pane to
	# idle ("come back and look"); a genuine permission block (wait) stays red,
	# and a pane with no agent (empty state) gets nothing.
	if [ "$(pane_get "$self" @agent_pane_state)" = done ]; then
		pane_set "$self" @agent_pane_state idle
		pane_set "$self" @agent_pane_tool "$tool"
	fi
	;;
done)
	n=$(subs_of "$self")
	seen=$(pane_get "$self" @agent_pane_seen)
	pane_set "$self" @agent_pane_tool "$tool"
	if [ "$n" -gt 0 ] && [ "$n" != "${seen:-}" ]; then
		# Subagents still out, and the count has moved since the last stop — real work
		# is landing, so hold the green back.
		pane_set "$self" @agent_pane_state busy
		pane_set "$self" @agent_pane_pending 1
		pane_set "$self" @agent_pane_seen "$n"
	else
		# Either nothing is out, or we stopped twice with the count frozen — those
		# increments are orphaned (a subagent denied or interrupted never reports a
		# stop) and must not pin this pane yellow forever.
		pane_set "$self" @agent_pane_state done
		pane_set "$self" @agent_pane_subs 0
		pane_del "$self" @agent_pane_pending
		pane_del "$self" @agent_pane_seen
	fi
	;;
sub+)
	pane_set "$self" @agent_pane_subs "$(($(subs_of "$self") + 1))"
	pane_set "$self" @agent_pane_tool "$tool"
	;;
sub-)
	n=$(subs_of "$self")
	[ "$n" -gt 0 ] && n=$((n - 1))
	pane_set "$self" @agent_pane_subs "$n"
	# A decrement means something FINISHED. It is never evidence that work is
	# running, so it must not assert busy — it only resolves a deferred done.
	if [ "$n" -eq 0 ] && [ -n "$(pane_get "$self" @agent_pane_pending)" ]; then
		pane_set "$self" @agent_pane_state done
		pane_del "$self" @agent_pane_pending
		pane_del "$self" @agent_pane_seen
	fi
	;;
clear)
	for o in @agent_pane_state @agent_pane_subs @agent_pane_pending @agent_pane_seen @agent_pane_tool; do
		pane_del "$self" "$o"
	done
	;;
*)
	echo "agent-state: unknown action '$action' (busy|resume|wait|idle|done|sub+|sub-|clear|viewed)" >&2
	exit 1
	;;
esac

refresh_window "$self"
