[color]
	diff = true
	status = true
	ui = true
  interactive = true
  branch = true
[core]
  autocrlf = input
	editor = nvim
	pager = delta
[gpg]
	format = ssh
[gpg "ssh"]
	allowedSignersFile = ~/.config/git/allowed_signers
{{ if (stat "/opt/1Password/op-ssh-sign") }}
    program = "/opt/1Password/op-ssh-sign"
{{ else if (stat "/Applications/1Password.app/Contents/MacOS/op-ssh-sign") }}
    program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"
{{ end }}
[mergetool]
	hideResolved = true
[commit]
	gpgsign = true
	verbose = true
[interactive]
	diffFilter = delta --color-only
[include]
	path = ~/.config/delta/delta.config
[delta]
	navigate = true
	hyperlinks = true
[pretty]
	# Aligned table. Only %an is padded — %h and %as are already fixed-width, and
	# padding the LAST column (%s) would both truncate long subjects and leave
	# trailing whitespace on every line, breaking copy-paste and `git lg | grep`.
	# %<(N,trunc) pads by display column, so multibyte names (Różalski) stay in line.
	# No --graph here: a merge prefix is 2 cols on a plain commit but 4 on a merge,
	# which skews every column after it.
	# %G? is the signature verdict, always exactly 1 column, so it sits mid-row
	# without disturbing alignment. Left raw and uncoloured here on purpose: the
	# `lg` alias runs it through ~/.local/bin/git-lg, which turns the letter into
	# a symbol and colours it by verdict — neither of which a pretty format can do,
	# since git log has no conditionals. Using --pretty=tbl directly still works
	# and just shows git's raw letter.
	# Needs gpg.ssh.allowedSignersFile set or every commit reports E.
	# ponytail: ~5ms per SIGNED commit, since each one shells out to verify;
	# unsigned ones are free. Paged use only formats a screenful so it stays
	# instant, but `git lg | grep` over a long signed history drags — drop %G?
	# into a separate alias if that ever bites.
	tbl = "%C(auto)%h%C(reset) %G? %C(blue)%as%C(reset) %C(green)%<(14,trunc)%an%C(reset) %s%C(auto)%d"
	# Free-flowing, for when topology matters more than scanning.
	# Never add -p to the graph aliases: the graph prefix on diff lines defeats
	# delta's parser and it silently falls back to git's own colours.
	gph = "%C(auto)%h %C(blue)%as%C(reset) %C(green)%an%C(reset) %s%C(auto)%d"
[pager]
	# `!` aliases are not paged by default; this restores it, and tells git-lg it
	# may still emit colour even though its stdout is now a pipe.
	lg = true
[alias]
	lg = "!git-lg"
	lgg = log --graph --pretty=gph
	lga = log --graph --pretty=gph --all
	last = log -1 --stat
	st = status --short
	ss = status
[column]
	# auto, not always: disables itself when piped, so nothing that parses
	# git output breaks.
	ui = auto
[status]
	showStash = true
	branch = true
[rebase]
	autosquash = true
[init]
	defaultBranch = main
[pull]
	rebase = true
[push]
	autoSetupRemote = true
[fetch]
	prune = true
[diff]
	colorMoved = default
	# Cleaner than the default myers on repetitive/structured code.
	algorithm = histogram
[merge]
	conflictStyle = zdiff3
[rerere]
	enabled = true
[includeIf "hasconfig:remote.*.url:workgit:*"]
	path = "~/.config/git/.gitconfig_work"
[includeIf "hasconfig:remote.*.url:personalgit:*"]
	path = "~/.config/git/.gitconfig_private"
