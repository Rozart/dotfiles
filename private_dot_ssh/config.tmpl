Host personalgit
	HostName github.com
	User git
	IdentityFile ~/.ssh/id_github_auth.pub
	IdentitiesOnly yes

Host workgit
	HostName github.com
	User git
	IdentityFile ~/.ssh/id_github_auth.pub
	IdentitiesOnly yes

{{- if eq .chezmoi.os "darwin" }}
Host home-nas
	HostName 192.168.0.36
	User rozart
	IdentityFile ~/.ssh/home-nas.pub
	IdentitiesOnly yes

Host proxmox
	HostName 192.168.0.40
	User root
	IdentityFile ~/.ssh/proxmox.pub
	IdentitiesOnly yes

Host programium-internal
	HostName 159.195.159.195
	User rozart
	IdentityFile ~/.ssh/programium-internal.pub
	IdentitiesOnly yes

Host dev-station
	HostName 192.168.0.41
	User rozart
	IdentityFile ~/.ssh/dev-station.pub
	IdentitiesOnly yes
	LocalForward 4200 localhost:4200
	LocalForward 4201 localhost:4201
	LocalForward 4300 localhost:4300
	LocalForward 4321 localhost:4321
	LocalForward 3100 localhost:3100
	LocalForward 3000 localhost:3000
	LocalForward 3389 localhost:3389
	LocalForward 8385 localhost:8384
	LocalForward 5173 localhost:5173
	LocalForward 8100 100.85.168.15:8000
	LocalForward 3001 100.85.168.15:3000
	RequestTTY yes
	RemoteCommand tmux new-session -A -s dev-station
	LogLevel QUIET

Host docker-host
	HostName 192.168.0.46
	User rozart
	IdentityFile ~/.ssh/docker-host.pub
	IdentitiesOnly yes
	RequestTTY yes
	RemoteCommand tmux new-session -A -s docker-host
	LogLevel QUIET

Host media-host
	HostName 192.168.0.49
	User rozart
	IdentityFile ~/.ssh/media-host.pub
	IdentitiesOnly yes
	RequestTTY yes
	RemoteCommand tmux new-session -A -s media-host
	LogLevel QUIET

Host proxmox-tailscale
	HostName 192.168.0.45
	User root
	IdentityFile ~/.ssh/proxmox-tailscale-lxc.pub
	IdentitiesOnly yes

Host pve-remote
	HostName proxmox.home.rozart.dev
	User root

Host dev-remote
	HostName dev-station.home.rozart.dev
	User rozart

Host *
	IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
	ServerAliveInterval 60
	ServerAliveCountMax 3
	ForwardAgent yes
{{- end }}
